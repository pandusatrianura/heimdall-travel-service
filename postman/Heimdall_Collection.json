        {
            "name": "1. Basic Aggregation & Normalization",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"origin\": \"CGK\",\n  \"destination\": \"DPS\",\n  \"departureDate\": \"2025-12-15\",\n  \"passengers\": 1\n}"
                },
                "url": {
                    "raw": "{{base_url}}/api/v1/search",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "search"
                    ]
                },
                "description": "Fetches flight data from multiple airlines, normalizes data into a common format, and correctly handles timezone shifts from WIB (+07:00) to WITA (+08:00) mathematically."
            },
            "response": []
        },
        {
            "name": "2. Search Filter: Airlines & Max Price",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"origin\": \"CGK\",\n  \"destination\": \"DPS\",\n  \"departureDate\": \"2025-12-15\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/api/v1/search?airlines=Garuda Indonesia&max_price=2000000",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "search"
                    ],
                    "query": [
                        {
                            "key": "airlines",
                            "value": "Garuda Indonesia"
                        },
                        {
                            "key": "max_price",
                            "value": "2000000"
                        }
                    ]
                },
                "description": "Filters the payload correctly requiring only Garuda flights under a specific price threshold."
            },
            "response": []
        },
        {
