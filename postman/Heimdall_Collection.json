        {
            "name": "3. Core: Price Comparison & Ranking",
            "item": [
                {
                    "name": "Rank by Best Value",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"origins\": \"CGK\",\n  \"destinations\": \"DPS\",\n  \"departureDate\": \"2025-12-15\",\n  \"passengers\": 1,\n  \"cabinClass\": \"economy\",\n  \"sort_by\": \"best_value\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/search",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "search"
                            ]
                        },
                        "description": "Requirement 3: Compare prices and convenience to rank flights using the Best Value algorithm. Default score formula: (0.6 x normalized price) + (0.4 x normalized duration). Lower score ranks higher, so the default behavior slightly favors cheaper flights while still considering speed. Short example: if Flight X has normalized price 0.0 and normalized duration 1.0, its score is 0.4; if Flight Y has normalized price 1.0 and normalized duration 0.0, its score is 0.6. In that case Flight X ranks above Flight Y. Concrete mock-data example: QZ7250 has price 485000 and duration 260, GA400 has price 1250000 and duration 110, and JT650 has price 780000 and duration 230. For JT650, minPrice=485000, maxPrice=1250000, minDuration=110, maxDuration=260, so normalizedPrice~=0.386, normalizedDuration=0.8, and final score~=0.552."
                    }
                },
                {
                    "name": "Sort by Lowest Price",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"origins\": \"CGK\",\n  \"destinations\": \"DPS\",\n  \"departureDate\": \"2025-12-15\",\n  \"passengers\": 1,\n  \"cabinClass\": \"economy\",\n  \"sort_by\": \"price_lowest\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/search",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "search"
                            ]
                        },
                        "description": "Requirement 3: Basic price comparison and sorting."
                    }
                }
            ]
